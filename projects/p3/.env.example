# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://lingua:lingua@localhost:5434/linguaclass_p3"

# ─── Auth (NextAuth v5) ──────────────────────────────────────
AUTH_SECRET="your-secret-key-here"
AUTH_URL="http://localhost:3002"
NEXTAUTH_URL="http://localhost:3002"

# ─── SMTP ────────────────────────────────────────────────────
# 개발: MailHog (인증 불필요). 도커 compose 안에서는 SMTP_HOST=mailhog 가 기본값.
# 실제 메일 인증을 쓰려면 아래를 진짜 SMTP 로 채운다. (예: Gmail SMTP)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587            # 465 면 SSL, 587 이면 STARTTLS
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=앱_비밀번호      # Gmail 은 2단계인증 후 "앱 비밀번호" 발급
SMTP_HOST="localhost"
SMTP_PORT="1027"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@linguaclass.kr"

# ─── Cron 보호 시크릿 ────────────────────────────────────────
CRON_SECRET="change-me"

# ─── 토스페이먼츠 결제위젯 (테스트) ──────────────────────────
# 위젯은 gck/gsk 키 세트를 사용한다. (API 개별연동의 ck/sk 와 섞으면 INVALID_API_KEY)
# 아래는 토스 공식 문서 제공 테스트 키 — 실제 금액이 청구되지 않는다.
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm"
TOSS_SECRET_KEY="test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6"
